{
  "scripts": {
    "start": "node server.js",
    "dev:react": "vite --config frontend-react/vite.config.js",
    "build": "vite build --config frontend-react/vite.config.js",
    "dev": "concurrently \"node --watch server.js\" \"npm run dev:react\"",
    "mobile:build": "npm run build && cap sync",
    "mobile:android": "npm run mobile:build && cap open android",
    "mobile:ios": "npm run mobile:build && cap open ios",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "mysql2": "^3.15.2",
    "nodemailer": "^8.0.10",
    "puppeteer": "^24.36.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "react-toastify": "^11.1.0",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
